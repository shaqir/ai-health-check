# ============================================
# AI Health Check — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# --- LLM Configuration ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-sonnet-4-6-20250415
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30

# --- Database ---
DATABASE_URL=sqlite:///./aiops.db

# --- JWT Authentication ---
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- App Settings ---
APP_NAME=AI Ops Control Room
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Evaluation Defaults ---
DRIFT_THRESHOLD=75.0
EVAL_SCHEDULE_MINUTES=60
HEALTH_CHECK_SCHEDULE_MINUTES=5
