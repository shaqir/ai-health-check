# ============================================
# AI Health Check — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# --- LLM Configuration ---
# Two-model architecture:
#   LLM_MODEL    = actor (service under test, synthesis tasks). Defaults to Sonnet.
#   JUDGE_MODEL  = factuality + hallucination judge (merged into one call). Defaults
#                  to Haiku — cheaper, faster, different family from the actor to
#                  reduce self-scoring correlation.
# Input safety is single-layer regex (see backend/app/services/safety.py).
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Canonical undated IDs — resolve to the latest snapshot within family.
# Dated snapshots (e.g. claude-sonnet-4-6-20250415) are fragile; Anthropic
# retires older ones and the API returns 404. The undated form is safer
# as a default. Pricing lookup in model_catalog.py normalizes both forms
# to the same rates, so switching to dated snapshots later stays cheap.
LLM_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-haiku-4-5
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30

# --- Database ---
DATABASE_URL=sqlite:///./aiops.db

# --- JWT Authentication ---
# Generate a real signing key with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# The sentinel below is intentionally shaped as obvious placeholder
# text (SHOUTY_SNAKE_CASE, under the recommended 32-char minimum), so
# a careless `cp .env.example .env` cannot produce a running
# deployment with a trivially-guessable signing key — anyone who read
# this file on the public repo could forge admin JWTs otherwise. See
# RISK_REGISTER R19 for context.
SECRET_KEY=REPLACE_ME_WITH_GENERATED_VALUE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- App Settings ---
APP_NAME=AI Health Check
DEBUG=true
# Set to true to echo every SQL statement to the terminal. Off by default
# so demos don't flood the log with SELECTs. Keep DEBUG separate.
LOG_SQL=false
# Set to false to disable the background health check job. Useful for
# demos so metrics don't shift mid-narration.
SCHEDULER_ENABLED=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Evaluation Defaults ---
DRIFT_THRESHOLD=75.0
HEALTH_CHECK_SCHEDULE_MINUTES=5
# How often the background job runs evaluations against every active
# service that has test cases. Set SCHEDULER_ENABLED=false to opt out.
EVAL_SCHEDULE_MINUTES=60

# --- API Budget & Rate Limits ---
# Soft limits — call is rejected only AFTER exceeding. 0 = unlimited.
API_DAILY_BUDGET=5.0
API_MONTHLY_BUDGET=25.0
API_MAX_CALLS_PER_MINUTE=30
API_MAX_CALLS_PER_USER_PER_MINUTE=20
MAX_PROMPT_LENGTH=10000

# --- Hard Caps (single-gatekeeper enforcement) ---
# Every Claude call passes through enforce_call_limits() before hitting the
# network. These reject calls that would blow an unreasonable amount of
# money, tokens, or prompt length in a single shot — a defense against
# bugs and misuse, not normal operation. Raise in production if needed.
HARD_MAX_COST_PER_CALL_USD=0.05
HARD_MAX_TOKENS_PER_CALL=2000
HARD_MAX_PROMPT_CHARS=12000
