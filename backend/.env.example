# ============================================
# AI Health Check — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# --- LLM Configuration ---
# Two-tier model economy:
#   LLM_MODEL       = actor (service under test, synthesis tasks). Defaults to Sonnet.
#   JUDGE_MODEL     = factuality + hallucination judge. Defaults to Haiku — cheaper,
#                     faster, different size/training emphasis from the actor to
#                     reduce "model scoring itself" correlation.
#   INJECTION_MODEL = prompt-injection classifier run on every input as a second
#                     layer over the regex tripwire. Fail-open on classifier outage.
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-sonnet-4-6-20250415
JUDGE_MODEL=claude-haiku-4-5-20251001
INJECTION_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30

# --- Database ---
DATABASE_URL=sqlite:///./aiops.db

# --- JWT Authentication ---
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- App Settings ---
APP_NAME=AI Health Check
DEBUG=true
# Set to true to echo every SQL statement to the terminal. Off by default
# so demos don't flood the log with SELECTs. Keep DEBUG separate.
LOG_SQL=false
# Set to false to disable the background health check job. Useful for
# demos so metrics don't shift mid-narration.
SCHEDULER_ENABLED=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Evaluation Defaults ---
DRIFT_THRESHOLD=75.0
HEALTH_CHECK_SCHEDULE_MINUTES=5
# How often the background job runs evaluations against every active
# service that has test cases. Set SCHEDULER_ENABLED=false to opt out.
EVAL_SCHEDULE_MINUTES=60
